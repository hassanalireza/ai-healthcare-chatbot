    {
      "cell_type": "code",
      "execution_count": 22,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "oiS--W3xgdlG",
        "outputId": "097ed5f5-fdd3-487a-b1b3-bfaa656e8377"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Overwriting medbot_app.py\n"
          ]
        }
      ],
      "source": [
        "%%writefile medbot_app.py\n",
        "import streamlit as st\n",
        "from langchain.schema import BaseRetriever\n",
        "import numpy as np\n",
        "import faiss\n",
        "import pickle\n",
        "import time\n",
        "import google.generativeai as genai\n",
        "\n",
        "# Configure the Gemini API key\n",
        "genai.configure(api_key=\"YOUR_API_KEY_HERE")\n",
        "\n",
        "# Helper function for Gemini response generation\n",
        "def generate_gemini_response(prompt):\n",
        "    \"\"\"Generate a response using Gemini.\"\"\"\n",
        "    try:\n",
        "        # Use the Gemini model for content generation\n",
        "        model = genai.GenerativeModel(\"gemini-1.5-flash\")\n",
        "        response = model.generate_content(prompt)\n",
        "        return response.text\n",
        "    except Exception as e:\n",
        "        return f\"Error generating response: {e}\"\n",
        "\n",
        "# Download the embedding model only once\n",
        "@st.cache_resource\n",
        "def load_embeddings():\n",
        "    from langchain.embeddings import HuggingFaceEmbeddings\n",
        "    return HuggingFaceEmbeddings(model_name=\"sentence-transformers/all-MiniLM-L6-v2\")\n",
        "\n",
        "#start_time_emb_download = time.time()\n",
        "#st.write(\"Downloading embedding model...\")\n",
        "embeddings = load_embeddings()\n",
        "#end_time_emb_download = time.time()\n",
        "#embedding_download_duration = end_time_emb_download - start_time_emb_download\n",
        "#st.write(f\"Time for embedding download: {embedding_download_duration:.4f} seconds\")\n",
        "\n",
        "# Load the FAISS index and transfer to GPU only once\n",
        "@st.cache_resource\n",
        "def load_index():\n",
        "    index = faiss.read_index(\"/content/drive/MyDrive/Med/medical_chatbot_full.index\")\n",
        "    res = faiss.StandardGpuResources()\n",
        "    index = faiss.index_cpu_to_gpu(res, 0, index)\n",
        "    return index\n",
        "\n",
        "#start_time_index_load = time.time()\n",
        "#st.write(\"Loading FAISS index...\")\n",
        "index = load_index()\n",
        "#end_time_index_load = time.time()\n",
        "#index_load_duration = end_time_index_load - start_time_index_load\n",
        "#st.write(f\"Time for index load: {index_load_duration:.4f} seconds\")\n",
        "\n",
        "# Load precomputed embeddings only once\n",
        "@st.cache_resource\n",
        "def load_vectors():\n",
        "    return np.load(\"/content/drive/MyDrive/Med/medical_chatbot_embeddings_full.npy\")\n",
        "\n",
        "#start_time_vectors_load = time.time()\n",
        "#st.write(\"Loading precomputed embeddings...\")\n",
        "vectors = load_vectors()\n",
        "#end_time_vectors_load = time.time()\n",
        "#vectors_load_duration = end_time_vectors_load - start_time_vectors_load\n",
        "#st.write(f\"Time for vectors load: {vectors_load_duration:.4f} seconds\")\n",
        "\n",
        "# Define a custom FAISS retriever\n",
        "class FaissRetriever(BaseRetriever):\n",
        "    def __init__(self, index, docs, embeddings, k=3):\n",
        "        super().__init__()\n",
        "        self._index = index\n",
        "        self._docs = docs\n",
        "        self._embeddings = embeddings\n",
        "        self._k = k\n",
        "\n",
        "    def _get_relevant_documents(self, query):\n",
        "        query_vector = self._embeddings.embed_query(query)\n",
        "        D, I = self._index.search(np.array([query_vector], dtype='float32'), k=self._k)\n",
        "        return [self._docs[i] for i in I[0] if i != -1]\n",
        "\n",
        "# Load document chunks\n",
        "@st.cache_resource\n",
        "def load_documents():\n",
        "    with open(\"/content/drive/MyDrive/Med/docs_full.pkl\", \"rb\") as f:\n",
        "        return pickle.load(f)\n",
        "\n",
        "docs = load_documents()\n",
        "\n",
        "# Initialize FAISS retriever\n",
        "faiss_retriever = FaissRetriever(index=index, docs=docs, embeddings=embeddings, k=5)\n",
        "\n",
        "# QA function using Gemini\n",
        "def qa_chain(query, context):\n",
        "    prompt = f\"\"\"\n",
        "Use the following pieces of information to answer the user's question.\n",
        "If you don't know the answer, just say that you don't know, don't try to make up an answer.\n",
        "\n",
        "Context: {context}\n",
        "Question: {query}\n",
        "\n",
        "Only return the helpful answer below and nothing else.\n",
        "Helpful answer:\n",
        "\"\"\"\n",
        "    return generate_gemini_response(prompt)\n",
        "\n",
        "# Streamlit app title\n",
        "st.title(\"MedBot - Medical Chatbot\")\n",
        "\n",
        "# Initialize conversation history in session state\n",
        "if \"conversation_history\" not in st.session_state:\n",
        "    st.session_state.conversation_history = []\n",
        "\n",
        "# User input\n",
        "user_input = st.text_input(\"Enter your query:\")\n",
        "\n",
        "# Process user input and add context\n",
        "if user_input:\n",
        "    context_docs = faiss_retriever._get_relevant_documents(user_input)\n",
        "    context = \"\\n\".join([doc.page_content for doc in context_docs])\n",
        "    # Prepare context by taking the most recent Q&A if available\n",
        "    if st.session_state.conversation_history:\n",
        "        prev_qa = st.session_state.conversation_history[-1]\n",
        "        context_prev = f\"Previous Question: {prev_qa['question']}\\nPrevious Answer: {prev_qa['answer']}\"\n",
        "        context = f\"Previous question context: {context_prev}\\n\\nExtracted Information:\\n{context}\"\n",
        "\n",
        "    # Measure the response time for performance monitoring\n",
        "    start_time_query = time.time()\n",
        "    response = qa_chain(user_input, context)\n",
        "    query_duration = time.time() - start_time_query\n",
        "    st.write(f\"Time for query processing: {query_duration:.4f} seconds\")\n",
        "\n",
        "    # Save to conversation history\n",
        "    st.session_state.conversation_history.append({\"question\": user_input, \"answer\": response})\n",
        "\n",
        "# Display up to two previous responses in chat format\n",
        "history_length = len(st.session_state.conversation_history)\n",
        "if history_length > 0:\n",
        "    # Only display the last two entries, or fewer if there are less than two\n",
        "    for item in st.session_state.conversation_history[max(0, history_length - 2):]:\n",
        "        st.write(f\"**Q:** {item['question']}\")\n",
        "        st.write(f\"**A:** {item['answer']}\")\n"
      ]
    },
